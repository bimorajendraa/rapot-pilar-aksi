DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306
DB_SSL=true
DB_CA_CERT=

# Auth (JWT)
JWT_SECRET=
JWT_EXPIRES_IN=12h

# Used only by `npm run seed:users` to create login accounts — never hardcode
# a default password in source code.
DEFAULT_EB_PASSWORD=
# Fallback password for any DEPT account without its own DEPT_PASSWORD_<DEPT> below.
DEFAULT_DEPT_PASSWORD=

# Optional per-department password overrides (recommended over sharing one
# password across all departments). Leave unset to fall back to
# DEFAULT_DEPT_PASSWORD above.
DEPT_PASSWORD_HRD=
DEPT_PASSWORD_IA=
DEPT_PASSWORD_SWF=
DEPT_PASSWORD_RTA=
DEPT_PASSWORD_IM=
DEPT_PASSWORD_EA=
DEPT_PASSWORD_ES=
DEPT_PASSWORD_SOCDEV=
DEPT_PASSWORD_MANAGE=
